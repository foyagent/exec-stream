{
  "name": "openclaw-exec-stream",
  "version": "0.1.0",
  "description": "Real-time Exec Stream plugin and standalone server for OpenClaw",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openclaw-exec-stream": "./dist/cli.js",
    "exec-stream-server": "./dist/standalone.js"
  },
  "keywords": [
    "openclaw",
    "exec",
    "terminal",
    "stream",
    "websocket",
    "plugin",
    "realtime"
  ],
  "author": "Boen <boen@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foyagent/exec-stream.git"
  },
  "bugs": {
    "url": "https://github.com/foyagent/exec-stream/issues"
  },
  "homepage": "https://github.com/foyagent/exec-stream#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "web/",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "Dockerfile",
    "docker-compose.yml",
    "ecosystem.config.js",
    "exec-stream.service",
    "examples/"
  ],
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^24.5.2",
    "@types/ws": "^8.5.14",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "prepare": "echo 'OpenClaw plugin ready'",
    "build": "tsc",
    "build:cli": "tsc && chmod +x dist/cli.js",
    "build:standalone": "tsc -p tsconfig.build.json",
    "start": "node dist/standalone.js",
    "start:standalone": "node dist/standalone.js",
    "test": "echo 'No tests yet'"
  }
}
